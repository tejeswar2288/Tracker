<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Task Reminder — WWW Task Tracker</title>
</head>
<body style="margin:0;padding:0;background:#f5f4f0;font-family:'Segoe UI',Arial,sans-serif;font-size:15px;color:#1a1917;">

<table width="100%" cellpadding="0" cellspacing="0" style="background:#f5f4f0;padding:40px 0;">
  <tr><td align="center">
    <table width="540" cellpadding="0" cellspacing="0" style="background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 16px rgba(0,0,0,0.08);">

      <!-- Header -->
      <tr>
        <td style="background:#1a1917;padding:20px 32px;">
          <span style="color:#fff;font-size:14px;font-weight:600;letter-spacing:0.2px;">WWW Task Tracker</span>
          <span style="color:rgba(255,255,255,0.4);font-size:12px;margin-left:10px;">Who does What by When</span>
        </td>
      </tr>

      <!-- Alert stripe -->
      <tr>
        <td style="background:{{alertBg}};padding:10px 32px;">
          <span style="color:{{alertColor}};font-size:11px;font-weight:700;letter-spacing:0.8px;text-transform:uppercase;">{{alertIcon}} {{alertLabel}}</span>
        </td>
      </tr>

      <!-- Body -->
      <tr>
        <td style="padding:32px 32px 28px;">

          <p style="margin:0 0 20px;font-size:15px;line-height:1.7;color:#1a1917;">
            Hi <strong>{{recipientName}}</strong>,
          </p>

          <p style="margin:0 0 16px;font-size:15px;line-height:1.7;color:#1a1917;">
            You have a task reminder from <strong>{{senderName}}</strong> on the <strong>{{projectName}}</strong> project.
          </p>

          <p style="margin:0 0 16px;font-size:15px;line-height:1.7;color:#1a1917;">
            {{{deadlineMessage}}}
          </p>

          <p style="margin:0 0 28px;font-size:15px;line-height:1.7;color:#1a1917;">
            Kindly stay committed with the deadline.
          </p>

          <!-- Task name box -->
          <table width="100%" cellpadding="0" cellspacing="0" style="background:#f9f8f5;border-left:3px solid {{alertColor}};border-radius:0 6px 6px 0;margin-bottom:28px;">
            <tr>
              <td style="padding:14px 18px;">
                <div style="font-size:11px;font-weight:600;letter-spacing:0.5px;text-transform:uppercase;color:#9e9c96;margin-bottom:5px;">Task</div>
                <div style="font-size:14px;font-weight:600;color:#1a1917;">{{taskName}}</div>
                <div style="font-size:12px;color:#6b6860;margin-top:4px;">Project: {{projectName}}</div>
              </td>
            </tr>
          </table>

          <div style="text-align:center;">
            <a href="{{appUrl}}" style="display:inline-block;background:#1a1917;color:#fff;font-size:13px;font-weight:500;padding:11px 28px;border-radius:8px;text-decoration:none;">
              Open Task Tracker →
            </a>
          </div>

        </td>
      </tr>

      <!-- Footer -->
      <tr>
        <td style="padding:16px 32px;border-top:1px solid rgba(0,0,0,0.06);background:#f9f8f5;">
          <p style="margin:0;font-size:11px;color:#9e9c96;line-height:1.6;">
            Sent by <strong>{{senderName}}</strong> via WWW Task Tracker &nbsp;·&nbsp; You are receiving this because you are assigned to this task.
          </p>
        </td>
      </tr>

    </table>
  </td></tr>
</table>

</body>
</html>
